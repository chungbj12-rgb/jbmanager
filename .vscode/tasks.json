{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "preview-server-bg",
      "type": "shell",
      "command": "${workspaceFolder}/run_preview.cmd",
      "windows": { "command": "${workspaceFolder}\\run_preview.cmd" },
      "linux": { "command": "python3 preview_server.py" },
      "osx": { "command": "python3 preview_server.py" },
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "reveal": "silent", "panel": "dedicated" },
      "problemMatcher": {
        "owner": "preview-server",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "PREVIEW_SERVER_READY"
        }
      }
    },
    {
      "label": "preview-split-right",
      "type": "shell",
      "command": "echo ${input:cmdSplitRight}",
      "problemMatcher": [],
      "presentation": { "reveal": "never", "echo": false, "focus": false, "panel": "shared" }
    },
    {
      "label": "preview-open-index",
      "type": "shell",
      "command": "echo ${input:cmdOpenSimpleBrowserIndex}",
      "problemMatcher": [],
      "presentation": { "reveal": "never", "echo": false, "focus": false, "panel": "shared" }
    },
    {
      "label": "preview-wait",
      "type": "shell",
      "command": "powershell -NoProfile -Command \"Start-Sleep -Milliseconds 700\"",
      "windows": { "command": "powershell -NoProfile -Command \"Start-Sleep -Milliseconds 700\"" },
      "linux": { "command": "sleep 0.7" },
      "osx": { "command": "sleep 0.7" },
      "problemMatcher": [],
      "presentation": { "reveal": "never", "echo": false, "focus": false, "panel": "shared" }
    },
    {
      "label": "preview-move-left",
      "type": "shell",
      "command": "echo ${input:cmdMoveGroupLeft}",
      "problemMatcher": [],
      "presentation": { "reveal": "never", "echo": false, "focus": false, "panel": "shared" }
    },
    {
      "label": "jb-preview-left",
      "type": "shell",
      "command": "echo Preview opened",
      "dependsOn": [
        "preview-server-bg",
        "preview-split-right",
        "preview-open-index",
        "preview-wait",
        "preview-move-left"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "dedicated", "showReuseMessage": false }
    }
  ],
  "inputs": [
    { "id": "cmdSplitRight", "type": "command", "command": "workbench.action.splitEditorRight" },
    {
      "id": "cmdOpenSimpleBrowserIndex",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://127.0.0.1:8765/index.html"]
    },
    { "id": "cmdMoveGroupLeft", "type": "command", "command": "workbench.action.moveEditorGroupLeft" }
  ]
}
