# Copy to .env — used by scripts/vercel-build.js (and Vercel Dashboard env).
# Local: after filling, run: set JB_WRITE_AUTH_CONFIG=1&& npm run vercel-build  (Windows)
#        or: JB_WRITE_AUTH_CONFIG=1 npm run vercel-build  (Unix)
# Vercel: set the same keys in Project → Settings → Environment Variables (no JB_WRITE_AUTH_CONFIG needed).

JB_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
JB_SUPABASE_ANON_KEY=your_anon_public_key
# JB_STORAGE_MODE=supabase
# JB_SYNTHETIC_EMAIL_DOMAIN=jbphonelogin.local
# JB_WRITE_AUTH_CONFIG=1
